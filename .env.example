APP_NAME=CHOMIN
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=th
APP_FALLBACK_LOCALE=th
APP_FAKER_LOCALE=th_TH

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@chomin.com
MAIL_FROM_NAME="CHOMIN"

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_PHONE=

DEPLOY_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Newsletter welcome discount
CHOMIN_NEWSLETTER_DISCOUNT_PERCENT=10
CHOMIN_NEWSLETTER_DISCOUNT_MAX=300
CHOMIN_NEWSLETTER_COUPON_DAYS=30
CHOMIN_NEWSLETTER_POPUP_DELAY_MS=25000

# Abandoned cart recovery
CHOMIN_ABANDONED_CART_FIRST_HOURS=4
CHOMIN_ABANDONED_CART_SECOND_HOURS=24

# Review request emails
CHOMIN_REVIEW_REQUEST_MIN_DAYS=7
CHOMIN_REVIEW_REQUEST_MAX_DAYS=8

# Payment methods
CHOMIN_PAYMENT_PROMPTPAY_ENABLED=true
CHOMIN_PAYMENT_COD_ENABLED=true
CHOMIN_PAYMENT_COD_FEE=30
CHOMIN_PAYMENT_COD_MIN_ORDER=0
CHOMIN_PAYMENT_COD_MAX_ORDER=50000
CHOMIN_PAYMENT_BANK_TRANSFER_ENABLED=false

# Social
CHOMIN_IG_HANDLE=chomin.th
CHOMIN_IG_URL=https://www.instagram.com/chomin.th/
CHOMIN_IG_TOKEN=

# Future integrations (placeholders — set when integrating):
# OMISE_PUBLIC_KEY=
# OMISE_SECRET_KEY=
# OMISE_WEBHOOK_SECRET=
# SHIPPOP_API_KEY=
# SHIPPOP_BASE_URL=https://mvp.shippop.com/api
# LINE_OA_ACCESS_TOKEN=
# LINE_OA_CHANNEL_SECRET=

VITE_APP_NAME="${APP_NAME}"
